---
/**
 * BeforeAfter — two columns (→ stacked under 900px) that frame a comparison.
 * Each side takes a header (tag/version/title) and a `before` / `after` slot.
 */
interface Props {
  beforeTag?: string;
  beforeVer?: string;
  beforeTitle?: string;
  afterTag?: string;
  afterVer?: string;
  afterTitle?: string;
}

const {
  beforeTag = 'Before',
  beforeVer,
  beforeTitle,
  afterTag = 'After',
  afterVer,
  afterTitle,
} = Astro.props;
---

<div class="dgm-ba">
  <div class="dgm-ba__col">
    <header class="dgm-ba__head">
      <span class="dgm-ba__tag">{beforeTag}</span>
      {beforeVer && <span class="dgm-ba__ver">{beforeVer}</span>}
      {beforeTitle && <p class="dgm-ba__title">{beforeTitle}</p>}
    </header>
    <slot name="before" />
  </div>
  <div class="dgm-ba__col">
    <header class="dgm-ba__head dgm-ba__head--after">
      <span class="dgm-ba__tag">{afterTag}</span>
      {afterVer && <span class="dgm-ba__ver">{afterVer}</span>}
      {afterTitle && <p class="dgm-ba__title">{afterTitle}</p>}
    </header>
    <slot name="after" />
  </div>
</div>
