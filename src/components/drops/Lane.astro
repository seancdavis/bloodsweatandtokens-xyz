---
/**
 * Lane — a labelled tier/group that arranges its Node children in a row
 * (default) or column. `framed` draws a dashed box around the group.
 */
interface Props {
  label?: string;
  dir?: 'row' | 'col';
  framed?: boolean;
}

const { label, dir = 'row', framed = false } = Astro.props;
---

<div class:list={['dgm-lane', framed && 'dgm-lane--framed']}>
  {label && <p class="dgm-lane__label">{label}</p>}
  <div class:list={['dgm-lane__nodes', `dgm-lane__nodes--${dir}`]}>
    <slot />
  </div>
</div>
