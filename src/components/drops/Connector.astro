---
/**
 * Connector — a directional edge between tiers/nodes. A flow element (no
 * coordinates): drop it between two Lanes (vertical) or two Nodes (horizontal).
 * dir: down | up | right | left | bi (vertical ↕) | bi-h (horizontal ↔)
 */
interface Props {
  dir?: 'down' | 'up' | 'right' | 'left' | 'bi' | 'bi-h';
  label?: string;
  tone?: 'default' | 'accent';
}

const { dir = 'down', label, tone = 'default' } = Astro.props;

const horizontal = dir === 'right' || dir === 'left' || dir === 'bi-h';
const startHead =
  dir === 'up' || dir === 'bi' ? 'up' : dir === 'left' || dir === 'bi-h' ? 'left' : null;
const endHead =
  dir === 'down' || dir === 'bi' ? 'down' : dir === 'right' || dir === 'bi-h' ? 'right' : null;
---

<div
  class:list={[
    'dgm-conn',
    horizontal ? 'dgm-conn--h' : 'dgm-conn--v',
    tone === 'accent' && 'dgm-conn--accent',
  ]}
  aria-hidden="true"
>
  {startHead && <span class:list={['dgm-conn__head', `dgm-conn__head--${startHead}`]} />}
  <span class="dgm-conn__line" />
  {endHead && <span class:list={['dgm-conn__head', `dgm-conn__head--${endHead}`]} />}
  {label && <span class="dgm-conn__label">{label}</span>}
</div>
