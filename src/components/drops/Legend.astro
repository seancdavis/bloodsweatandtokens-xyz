---
/**
 * Legend — a key of swatches + labels. Use for the "what changed" callout.
 * tone: default (rule) | accent (blood) | gone (dashed, retired) | kept (bone)
 */
interface LegendItem {
  tone?: 'default' | 'accent' | 'gone' | 'kept';
  label: string;
}

interface Props {
  title?: string;
  items: LegendItem[];
}

const { title, items } = Astro.props;
---

<ul class="dgm-legend">
  {title && <li class="dgm-legend__title">{title}</li>}
  {items.map((item) => (
    <li class="dgm-legend__item">
      <span
        class:list={[
          'dgm-legend__swatch',
          item.tone && item.tone !== 'default' && `dgm-legend__swatch--${item.tone}`,
        ]}
      />
      {item.label}
    </li>
  ))}
</ul>
