---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { HostGrid } from '../../components/podcast/HostGrid';
import { SubscribePanel } from '../../components/podcast/SubscribePanel';
import { hosts, platformLinks, site } from '../../data/podcast';
---

<BaseLayout
  title="About"
  description="About Blood, Sweat & Tokens, a podcast about building under pressure."
  image={site.coverArt}
>
  <main class="page-main">
    <section class="about-panel" aria-labelledby="about-heading">
      <p class="terminal-command">bst@pressure:~$ less README.md</p>
      <h1 id="about-heading">{site.name}</h1>
      <p>
        {site.tagline} Taylor MacDonald and Sean C. Davis are documenting a real experiment: can you replace the
        content management layer with agents, natural language, and a thin data model without pretending the hard parts
        disappear?
      </p>
      <p>
        {site.seasonLabel}, <strong>{site.seasonTitle}</strong>, takes aim at the most expensive and least-loved layer
        of the web stack. The premise is simple: code between episodes, record what changed, and end every conversation
        with the next thing to build.
      </p>
    </section>
    <HostGrid hosts={hosts} />
    <SubscribePanel links={platformLinks} />
  </main>
</BaseLayout>
