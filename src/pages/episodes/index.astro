---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { EpisodeList } from '../../components/podcast/EpisodeList';
import { SubscribePanel } from '../../components/podcast/SubscribePanel';
import { episodes, platformLinks, site } from '../../data/podcast';
---

<BaseLayout
  title="Episodes"
  description="Browse every Blood, Sweat & Tokens episode with audio, video, show notes, and transcripts."
  image={site.coverArt}
>
  <main class="page-main">
    <section class="ep-hero" aria-labelledby="episodes-heading">
      <div>
        <p class="label label--blood ep-hero__kicker">The feed</p>
        <h1 class="ep-hero__title" id="episodes-heading">Every episode</h1>
      </div>
      <aside class="ep-hero__meta">
        <strong>{episodes.length} episodes</strong>
        {site.seasonLabel}: {site.seasonTitle}
      </aside>
    </section>
    <EpisodeList episodes={episodes} heading="All episodes" />
    <SubscribePanel links={platformLinks} />
  </main>
</BaseLayout>
