---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { EpisodeMediaPlayer } from '../../../components/podcast/EpisodeMediaPlayer';
import { EpisodeList } from '../../../components/podcast/EpisodeList';
import {
  durationClock,
  episodeCode,
  episodePath,
  episodes,
  formatEpisodeDate,
  latestEpisode,
  site,
  transcriptPreview,
  type Episode,
} from '../../../data/podcast';

export function getStaticPaths() {
  return episodes.map((episode) => ({
    params: { slug: episode.slug },
    props: { episode },
  }));
}

interface Props {
  episode: Episode;
}

const { episode } = Astro.props;
const relatedEpisodes = episodes.filter((item) => item.id !== episode.id).slice(0, 3);

const speakerMap: Record<string, string> = {
  'Taylor MacDonald': 'Taylor',
  'Sean C Davis': 'Sean',
  'Sean C. Davis': 'Sean',
};

const transcriptLines = episode.transcript
  .split(/\n{2,}/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean)
  .map((paragraph) => {
    const match = paragraph.match(/^([A-Z][A-Za-z.\s]{1,38}?):\s+([\s\S]+)$/);
    if (!match) return { who: '', text: paragraph };
    const rawWho = match[1].trim();
    return { who: speakerMap[rawWho] ?? rawWho, text: match[2].trim() };
  });
const episodeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'PodcastEpisode',
  name: episode.shortTitle,
  description: episode.summary,
  url: new URL(episodePath(episode), Astro.site ?? site.url).toString(),
  datePublished: episode.publishedAt,
  duration: `PT${Math.round(episode.durationSeconds / 60)}M`,
  partOfSeries: {
    '@type': 'PodcastSeries',
    name: site.name,
    url: site.url,
  },
  associatedMedia: [
    {
      '@type': 'MediaObject',
      contentUrl: episode.audioUrl,
      encodingFormat: 'audio/mpeg',
    },
    {
      '@type': 'VideoObject',
      embedUrl: `https://www.youtube-nocookie.com/embed/${episode.videoId}`,
      name: episode.shortTitle,
      uploadDate: episode.publishedAt,
    },
  ],
  transcript: transcriptPreview(episode.transcript, 1200),
};
---

<BaseLayout
  title={episode.shortTitle}
  description={episode.summary}
  image={site.coverArt}
  type="article"
  jsonLd={episodeJsonLd}
>
  <main class="page-main">
    <section class="ep-hero" aria-labelledby="episode-heading">
      <div>
        <p class="label label--blood ep-hero__kicker">{site.seasonLabel} — {site.seasonTitle}</p>
        <h1 class="ep-hero__title" id="episode-heading">{episode.shortTitle}</h1>
      </div>
      <aside class="ep-hero__meta">
        <strong>Ep {episodeCode(episode)}</strong>
        {formatEpisodeDate(episode.publishedAt)} · {durationClock(episode.duration)}
      </aside>
    </section>

    <EpisodeMediaPlayer
      client:load
      id="episode-player"
      episodeCode={episodeCode(episode)}
      title={episode.shortTitle}
      audioUrl={episode.audioUrl}
      videoId={episode.videoId}
      defaultMode={episode.id === latestEpisode.id ? 'audio' : 'video'}
    />

    <section class="ep-body">
      <article class="copy">
        <h2>Show notes</h2>
        <div set:html={episode.descriptionHtml} />
      </article>
      <aside class="notes" aria-labelledby="episode-takeaways">
        <h2 id="episode-takeaways">Takeaways</h2>
        <ul>
          {episode.takeaways.map((takeaway) => <li>{takeaway}</li>)}
        </ul>
        <h2>Chapters</h2>
        <ul>
          {episode.chapters.map((chapter) => <li>{chapter}</li>)}
        </ul>
        <p>
          <a href={episode.transcriptUrl} target="_blank" rel="noreferrer">Source transcript →</a>
        </p>
      </aside>
    </section>

    <section class="transcript" aria-labelledby="transcript-heading">
      <details>
        <summary id="transcript-heading">Transcript</summary>
        <div class="transcript__content">
          {
            transcriptLines.map((line) => (
              <p class="tr-line">
                {line.who && <span class="tr-who">{line.who}</span>}
                <span class="tr-text">{line.text}</span>
              </p>
            ))
          }
        </div>
      </details>
    </section>

    <EpisodeList episodes={relatedEpisodes} heading="keep listening" />
  </main>
</BaseLayout>
