---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BoarMark } from '../components/brand/BoarMark';
import { EpisodeList } from '../components/podcast/EpisodeList';
import { EpisodeMediaPlayer } from '../components/podcast/EpisodeMediaPlayer';
import { HostGrid } from '../components/podcast/HostGrid';
import { SubscribePanel } from '../components/podcast/SubscribePanel';
import {
  durationClock,
  episodeCode,
  episodePath,
  episodes,
  hosts,
  latestEpisode,
  platformLinks,
  site,
} from '../data/podcast';

const podcastJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: site.name,
  description: site.description,
  url: site.url,
  image: site.coverArt,
  inLanguage: 'en',
  sameAs: platformLinks.map((link) => link.url),
};

const marqueeItems = [
  'Ship the prototype',
  'Delete your CMS',
  'Follow the tokens',
  'Real deadlines',
  'No slides',
];

const premise = [
  {
    title: 'Real builds',
    body: 'Every episode comes out of work happening between recordings: prototypes, dead ends, and production pressure.',
  },
  {
    title: 'AI under load',
    body: 'Agentic workflows as they actually behave inside real product systems — not the demo, the deadline.',
  },
  {
    title: 'Season 1',
    body: `${site.seasonTitle} asks whether natural language, agents, and a thin data layer can replace the admin UI.`,
  },
];
---

<BaseLayout title={site.name} description={site.description} image={site.coverArt} jsonLd={podcastJsonLd}>
  <main class="page-main">
    <section class="hero" aria-labelledby="hero-heading">
      <BoarMark className="hero__boar" />
      <div class="hero__lead">
        <p class="label label--blood hero__kicker">A podcast about building under pressure</p>
        <h1 class="hero__title" id="hero-heading">
          Blood,<br />Sweat &amp;<em>Tokens</em>
        </h1>
      </div>
      <div class="hero__aside">
        <p class="hero__sub">{site.description}</p>
        <div class="hero__actions">
          <a class="btn btn--blood" href="#latest-player">
            <span class="btn__tri" aria-hidden="true">▶</span>
            Play Ep {episodeCode(latestEpisode)}
          </a>
          <a class="btn" href="/episodes/">Browse episodes</a>
        </div>
      </div>
    </section>

    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        {marqueeItems.map((item) => <span>{item}</span>)}
        {marqueeItems.map((item) => <span>{item}</span>)}
      </div>
    </div>

    <div class="latest">
      <span class="latest__tag">Latest</span>
      <h2 class="latest__title">
        <a href={episodePath(latestEpisode)}>{latestEpisode.shortTitle}</a>
      </h2>
      <span class="latest__meta">Ep {episodeCode(latestEpisode)} · {durationClock(latestEpisode.duration)}</span>
    </div>

    <EpisodeMediaPlayer
      client:load
      id="latest-player"
      episodeCode={episodeCode(latestEpisode)}
      title={latestEpisode.shortTitle}
      duration={latestEpisode.duration}
      audioUrl={latestEpisode.audioUrl}
      videoId={latestEpisode.videoId}
      defaultMode="audio"
    />

    <section class="premise" aria-label="Show premise">
      {
        premise.map((item, index) => (
          <article class="premise__card">
            <span class="premise__no">{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))
      }
    </section>

    <EpisodeList episodes={episodes} limit={4} heading="Recent episodes" />
    <HostGrid hosts={hosts} />
    <SubscribePanel links={platformLinks} />
  </main>
</BaseLayout>
